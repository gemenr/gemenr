# Active model configuration ID.
model = "default"

# Provider definitions.
[providers.anthropic]
type = "anthropic"
api_key = "replace-me"
api_endpoint = "https://api.anthropic.com/v1/messages"

# Selectable model definitions.
[models.default]
provider = "anthropic"
model = "claude-haiku-4-5-20251001"
max_tokens = 1024


# Lark long-connection adapter.
[access.lark]
app_id = "cli_aabbccddeeff"
app_secret = "replace-me"
ws_endpoint = "wss://open.feishu.cn/ws"
debounce_ms = 500

# Cron daemon jobs. Run with `gemenr daemon`.
[[cron]]
name = "daily-summary"
schedule = "0 0 9 * * *"
prompt = "Summarize the latest workspace status and report blockers."
tools = ["fs.read"]
report_to = "stdio:"
